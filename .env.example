# Pluto public RPC (HTTPS)
ETERNAX_NODE0_URL=https://pluto-testnet.eternax.ai/rpc0
ETERNAX_NODE1_URL=https://pluto-testnet.eternax.ai/rpc1

# Required: same 64-byte SPHINCS+ secret as the web wallet (account 1 below)
PLUTO_SPHINCS_SK_HEX=0xece714856a1061c7b3d0da60bac2acf3ea2c5604b6863fa82bc58bd6ab91f6469c6f89df16e669a903de39d89787f42abca9cb41e4fbe70d4e388b5edc444d68

# record | transfer (transfer = verified pot dispatch)
PLUTO_MODE=transfer

# Set to 0 to verify on both nodes without submitting
PLUTO_SUBMIT=1

PLUTO_DEST_HEX=0x3Cd0A705a2DC65e5b1E1205896BaA2be8A07c6e0
PLUTO_VALUE=1000000000000000000

# Optional fixed dev wallet seed
# PLUTO_SILMARILS_MASTER_SEED=eternax-testnet-wallet-seed-v1
