# Pluto public RPC (HTTPS)
ETERNAX_NODE0_URL=https://pluto-testnet.eternax.ai/rpc0
ETERNAX_NODE1_URL=https://pluto-testnet.eternax.ai/rpc1

# record (legacy SILMARILS record) | transfer (verified pot transfer)
DEMO_MODE=record

# Set to 0 to verify on both nodes without submitting
DEMO_SUBMIT=1

# transfer mode
DEMO_AUTH_NONCE=1
DEMO_DEST_HEX=0x3Cd0A705a2DC65e5b1E1205896BaA2be8A07c6e0
DEMO_VALUE=1000000000000000000

# record mode
DEMO_NONCE=1

# SPHINCS+ keys (optional; if omitted a new keypair is generated each run)
# DEMO_SPHINCS_SK_HEX=0x...
# DEMO_SPHINCS_PK_HEX=0x...

# SILMARILS master key (default matches silmarils-testnet-cli / testnet-submit.sh)
# DEMO_SILMARILS_MASTER_SEED=eternax-testnet-wallet-seed-v1

# Set to 1 to derive SILMARILS master from SPHINCS secret (apps/demo-web web wallet)
# DEMO_SILMARILS_MASTER_FROM_SPHINCS=0
